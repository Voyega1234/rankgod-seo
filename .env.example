# ── Gemini AI (required) ──────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza-xxxxx

# Model for main SEO analysis
GEMINI_MODEL=gemini-2.5-flash

# ── Vertex AI Grounding — Google Search (optional) ────────────────────────────
# Leave all GCP_ vars empty to skip grounding (system works without it)

# GCP Project ID — find at console.cloud.google.com
GCP_PROJECT_ID=your-gcp-project-id

# Vertex AI region (default: us-central1)
GCP_LOCATION=us-central1

# Model for grounding queries
GEMINI_VERTEX_MODEL=gemini-2.0-flash-001

# AUTH — choose one method:
#
# Local dev — path to service account JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#
# Vercel — paste full JSON content as single line:
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
#
# GCP-hosted (Cloud Run, GKE, App Engine) — leave both blank, auto-auth

# ── Database — Supabase Postgres connection string ────────────────────────────
# Example:
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
